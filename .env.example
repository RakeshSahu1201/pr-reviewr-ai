# ==============================================================
# pr-reviewer-ai — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the filled-in .env to version control.
# ==============================================================

# --- Go toolchain (only needed on this dev machine) ---
# Fixes go1.24.5 compile mismatch on systems with a partial go1.25 install:
# GOROOT=/home/rakesh/go-workspace/pkg/mod/golang.org/toolchain@v0.0.1-go1.25.0.linux-amd64

# --- Database ---
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=

# --- Encryption (AES-256-GCM key) ---
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY_HOURS=24

# --- GitLab ---
GITLAB_BASE_URL=https://gitlab.com
GITLAB_PROJECT_ID=mygroup/myrepo

# --- LLM API Keys (Multi-Provider Support) ---
# Configure at least one provider. The app falls back automatically.
# Get your keys at:
# Gemini: https://aistudio.google.com/app/apikey
# Groq: https://console.groq.com
# DeepSeek: https://platform.deepseek.com
# Mistral: https://console.mistral.ai
# Cerebras: https://cloud.cerebras.ai

GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
CEREBRAS_API_KEY=

# Option to override defaults
LLM_MODEL=gemini-1.5-flash

# Failover order (index 0 is tried first)
LLM_PROVIDER_ORDER=gemini,groq,deepseek,mistral,cerebras

# --- LLM Safety / Redaction ---
LLM_SANITIZE=true
LLM_CUSTOM_REDACT=MyCompany,internal-hostname


# --- Server ---
PORT=8080

# --- Postgres (used by docker-compose) ---
POSTGRES_PASSWORD=changeme
